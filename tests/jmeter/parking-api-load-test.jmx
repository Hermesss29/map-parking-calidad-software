            <stringProp name="JSONPostProcessor.match_numbers">1</stringProp>
            <stringProp name="JSONPostProcessor.defaultValues">-1</stringProp>
          </JSONPostProcessor>
          <hashTree/>
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Promover IDs → propiedades globales" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="text">
props.put(&quot;userId&quot;,    vars.get(&quot;userId&quot;)    ?: &quot;-1&quot;)
props.put(&quot;tarifaId&quot;,  vars.get(&quot;tarifaId&quot;)  ?: &quot;-1&quot;)
props.put(&quot;reservaId&quot;, vars.get(&quot;reservaId&quot;) ?: &quot;-1&quot;)
log.info(&quot;setUp → userId=${props.get(&apos;userId&apos;)} tarifaId=${props.get(&apos;tarifaId&apos;)} reservaId=${props.get(&apos;reservaId&apos;)}&quot;)
            </stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">false</stringProp>
            <stringProp name="script"></stringProp>
          </JSR223Sampler>
          <hashTree/>
        </hashTree>
      </hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="01 – Normal (5u × 10 iter)">
        <intProp name="ThreadGroup.num_threads">5</intProp>
        <intProp name="ThreadGroup.ramp_time">10</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
